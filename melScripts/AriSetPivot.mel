		$button[0]=`button -h 16 -l "X Center" -bgc $rgb_r1[0] $rgb_r1[1] $rgb_r1[2] -c "AriSetPivot_GO(8); AriSetPivot_Reload();"`;
		$button[1]=`button -h 16 -l "Y Center" -bgc $rgb_g1[0] $rgb_g1[1] $rgb_g1[2] -c "AriSetPivot_GO(9); AriSetPivot_Reload();"`;
		$button[2]=`button -h 16 -l "Z Center" -bgc $rgb_b1[0] $rgb_b1[1] $rgb_b1[2] -c "AriSetPivot_GO(10);AriSetPivot_Reload();"`;
	setParent..;
