	-af $button[0] "left"  0             -ap $button[0] "right" 0 33
	-ac $button[1] "left"  0 $button[0]  -ap $button[1] "right" 0 67
	-ac $button[2] "left"  0 $button[1]  -ap $button[2] "right" 0 100
	$form;
	$form=`formLayout -h 22`;
		$button[0]=`button -bgc $rgb_r1[0] $rgb_r1[1] $rgb_r1[2] -w 30 -h 10 -l "X Min" -c "AriSetPivot_GO(0);AriSetPivot_Reload();"`;
		$button[1]=`button -bgc $rgb_g1[0] $rgb_g1[1] $rgb_g1[2] -w 30 -h 10 -l "Y Min" -c "AriSetPivot_GO(1);AriSetPivot_Reload();"`;
		$button[2]=`button -bgc $rgb_b1[0] $rgb_b1[1] $rgb_b1[2] -w 30 -h 10 -l "Z Min" -c "AriSetPivot_GO(2);AriSetPivot_Reload();"`;
	setParent..;
	formLayout -e
	-af $button[0] "left"  0             -ap $button[0] "right" 0 33
	-af $button[0] "top"   0             -af $button[0] "bottom"  0
	-ac $button[1] "left"  0 $button[0]  -ap $button[1] "right" 0 67
	-af $button[1] "top"   0             -af $button[1] "bottom"  0
	-ac $button[2] "left"  0 $button[1]  -ap $button[2] "right" 0 100
	-af $button[2] "top"   0             -af $button[2] "bottom"  0
	$form;
	setParent..;
	$form = `formLayout -h 16 -vis false`;
		$button[0]=`button -h 16 -l "X" -bgc $rgb_r1[0] $rgb_r1[1] $rgb_r1[2] -c "AriSetPivot_Manipulator(0)"`;
		$button[1]=`button -h 16 -l "Y" -bgc $rgb_g1[0] $rgb_g1[1] $rgb_g1[2] -c "AriSetPivot_Manipulator(1)"`;
		$button[2]=`button -h 16 -l "Z" -bgc $rgb_b1[0] $rgb_b1[1] $rgb_b1[2] -c "AriSetPivot_Manipulator(2)"`;
	setParent..;
	formLayout -e
	-af $button[0] "left"  0             -ap $button[0] "right" 0 33
	-ac $button[1] "left"  0 $button[0]  -ap $button[1] "right" 0 67
	-ac $button[2] "left"  0 $button[1]  -ap $button[2] "right" 0 100
	$form;
	separator -h 4 ;
	$form=`formLayout`;
		$button[0] = `button -bgc 0.6 0.6 0.6 -l $label_wOriginPiv -c "AriSetPivot_GO(30)" -ann $label_rightOption`;
		popupMenu;
		menuItem -label "X" -c "AriSetPivot_GO(31)";
		menuItem -label "Y" -c "AriSetPivot_GO(32)";
		menuItem -label "Z" -c "AriSetPivot_GO(33)";
		$button[1] = `button -bgc 0.6 0.6 0.6 -l $label_lOriginPiv -c "AriSetPivot_moveLocalZero(0,0)" -ann $label_rightOption`;
	setParent..;
	formLayout -e
	-af $button[0] "left"  0             -ap $button[0] "right" 0 50
	-ac $button[1] "left"  0 $button[0]  -ap $button[1] "right" 0 100
	$form;
	separator -h 4 ;
	setParent..;
	setParent..;
	$AriReFreezeTrFrame[2] = `frameLayout -bgc 0.2 0.2 0.2 -cll 1 -cl $frameCl[2] -l "Move" -cc "AriSetPivot_windowSize()" -ec "AriSetPivot_windowSize()"`;
	columnLayout -adj true -co both 4;
	iconTextButton -h 28  -bgc  $valA $valA $valB -st "iconAndTextHorizontal" -l $label_ManipMove -i "channelBoxUseManips.png" -c "AriSetPivot_ManipulatorMove(3)" -ann $label_rightOption;
	popupMenu;
	menuItem -label "X" -c "AriSetPivot_ManipulatorMove(0)";
	menuItem -label "Y" -c "AriSetPivot_ManipulatorMove(1)";
	menuItem -label "Z" -c "AriSetPivot_ManipulatorMove(2)";
	$form=`formLayout -h 16 -vis false`;
		$button[0] = `button -h 16 -l "X" -bgc $rgb_r2[0] $rgb_r2[1] $rgb_r2[2] -c "AriSetPivot_ManipulatorMove(0)"`;
		$button[1] = `button -h 16 -l "Y" -bgc $rgb_g2[0] $rgb_g2[1] $rgb_g2[2] -c "AriSetPivot_ManipulatorMove(1)"`;
		$button[2] = `button -h 16 -l "Z" -bgc $rgb_b2[0] $rgb_b2[1] $rgb_b2[2] -c "AriSetPivot_ManipulatorMove(2)"`;
	setParent..;
	separator -h 4 ;
	formLayout -e
	-af $button[0] "left"  0             -ap $button[0] "right" 0 33
	-ac $button[1] "left"  0 $button[0]  -ap $button[1] "right" 0 67
	-ac $button[2] "left"  0 $button[1]  -ap $button[2] "right" 0 100
	$form;
	$form = `formLayout`;
		$button[0] = `button -bgc 0.6 0.6 0.6 -l $label_wOriginMove -c "move -rpr 0 0 0; AriSetPivot_getObjectPos();" -ann $label_rightOption`;
		popupMenu;
		menuItem -label "X" -c "move -rpr -x 0; AriSetPivot_getObjectPos();";
		menuItem -label "Y" -c "move -rpr -y 0; AriSetPivot_getObjectPos();";
		menuItem -label "Z" -c "move -rpr -z 0; AriSetPivot_getObjectPos();";
		$button[1] = `button -bgc 0.6 0.6 0.6 -l $label_lOriginMove -c "AriSetPivot_moveLocalZero(0,1); AriSetPivot_getObjectPos();" -ann $label_rightOption`;
	setParent..;
	formLayout -e
	-af $button[0] "left"  0 
	-ap $button[0] "right" 0 50
	-ac $button[1] "left"  0 $button[0]
	-ap $button[1] "right" 0 100
	$form;
	separator -h 4 ;
	button -h 20 -l $label_transAttrZero -c "AriReFrTrPv_transformAttrZero(0); AriSetPivot_getObjectPos();" -ann $label_rightOption;
	popupMenu;
		menuItem -label "X" -c "AriReFrTrPv_transformAttrZero(1)";
		menuItem -label "Y" -c "AriReFrTrPv_transformAttrZero(2)";
		menuItem -label "Z" -c "AriReFrTrPv_transformAttrZero(3)";
	separator -h 4 ;
	setParent..;
	formLayout -e
	-af $mainForm_child2 "left"  0
	-af $mainForm_child2 "right" 0
	-af $mainForm_child2 "bottom"   0
	-af $AriReFreezeTrFrame[4] "left"   0
	-af $AriReFreezeTrFrame[4] "right"  0
	-af $AriReFreezeTrFrame[4] "top"    0
	-ac $AriReFreezeTrFrame[4] "bottom" 0 $mainForm_child2
	$mainForm;
	setParent..;
	$AriReFreezeTrFrame[6] = `frameLayout -bgc 0.2 0.2 0.2 -cll 1 -cl $frameCl[6] -l "Orient" -cc "AriSetPivot_windowSize()" -ec "AriSetPivot_windowSize()"`;
	columnLayout -adj true -co both 4;
	text -l $label_manuOrient -align "left";
	$form = `formLayout`;
		$button[0] = `button -l "Pivot"  -bgc  $valA $valA $valB -c "AriSetPivot_PivotRotate(0,0)"`;
		popupMenu;
		menuItem -label $label_SetParentPivot -c "AriSetPivot_SetParentPivot(0)";
		$button[1] = `button -l "Rotate" -bgc  $valA $valA $valB -c "AriSetPivot_PivotRotate(1,0)"`;
	setParent..;
	formLayout -e
	-af $button[0] "left"  0 
	-ap $button[0] "right" 0 50
	-ac $button[1] "left"  0 $button[0]
	-ap $button[1] "right" 0 100
	$form;
	separator -h 4 ;
	button -h 20 -l $label_rotateAttrZero -c "AriReFrTrPv_transformAttrZero(10); AriSetPivot_getObjectPos();" -ann $label_rightOption;
	popupMenu;
		menuItem -label "X" -c "AriReFrTrPv_transformAttrZero(11)";
		menuItem -label "Y" -c "AriReFrTrPv_transformAttrZero(12)";
		menuItem -label "Z" -c "AriReFrTrPv_transformAttrZero(13)";
	separator -h 4 ;
	setParent..;
	setParent..;
	showWindow;
	AriSetPivot_windowSize();
	$AriSetPivot_JobNum = `scriptJob -p "AriSetPivot" -event "SelectionChanged" "AriSetPivot_changeSelect_GO();"`;
	AriSetPivot_changeSelect_GO();
	AriSetPivot_Load();
}
