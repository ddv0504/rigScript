//--------------------------------------------------------------------------
//
// ScriptName : AriSetPivot
// Contents   : フリーズしたトランスフォームを戻します。(トランスフォームの数値を原点からの距離にします)
//            : ピボットの位置を制御します。
// Author     : Ari
// Since      : 2015/06
// LastUpdate : 2021/06/27 回転値を親に転送する機能追加
//              2021/03/28 マニピュレータ回転方向の転送機能追加
//              2020/03/29 ローカル座標に対応
//                         疑似マニピュレーター機能追加
//              2018/08/19 座標情報と選択リスト表示機能追加
//              2018/03/29 CenterPivotの挙動を修正
//              2017/11/15 ボタンの表記間違えを修正
//              2017/11/11 MEL名変更
//                         ReFreeze実行時子を除外
//                         ボタン(機能)追加
//                         ボタン色調整
//              2016/08/28 ピボット座標設定をコンポーネントも対象に
//                         閉じたUIを記録
//              2016/03/13 UI整理。細かい機能追加。
//              2016/01/07 ReFreezeとFreezeをアニメーションキーに対応
//              2015/06/26 UI修正
//              2015/06/28 cm以外の単位に対応
//
//--------------------------------------------------------------------------



proc string[] getSelectToTransformList(){
	string $transformList[] = `ls -sl -tr`;
	string $selects[] = `ls -sl`;
	string $delTf[] = stringArrayRemove($transformList, $selects);
	string $vertexList[] = `polyListComponentConversion -tv $delTf`;
	string $shapes[]     = `polyListComponentConversion $vertexList`;	
	string $shapeToTf[] = `listRelatives -p -pa -type "transform" $shapes`;
	string $targetTransformList[] = stringArrayCatenate($transformList, $shapeToTf);
	return $targetTransformList;
}
proc int AriUnparentOne_ListNum (string $obj){
	int $num;
	string $parent[]=`listRelatives -p -pa $obj`;
	string $children[];
	if($parent[0]=="")	$children=`ls -as `;
	else $children=	`listRelatives -c -pa $parent[0]`;
	int $i=0;
	for($child in $children){
		if($child == $obj){
			$num=$i;
			break;
		}
		$i++;
	}
	return $num;
}
global proc AriSetPivot_PivotRotate(int $mode,int $parentFreeze){
	string $selectList[] = getSelectToTransformList();
	string $targetObj = $selectList[size($selectList)-1];
	string $baseObjList[] = $selectList;
	stringArrayRemoveAtIndex(size($selectList)-1, $baseObjList);
	vector $targetScale = `getAttr ($targetObj+".scale")`;
	setAttr ($targetObj+".scale") 1 1 1 ;
	int $manipTrue = `manipPivot -q -ov`;
	string $rotGroup;
	if($manipTrue){
		float $manipRot[] = `manipPivot -q -o`;
		$rotGroup = `group -em -name "AriReFreezeParent"`;
		setAttr ($rotGroup+".rotate") $manipRot[0] $manipRot[1] $manipRot[2];
		clear $baseObjList;
		$baseObjList[0] = $selectList[size($selectList)-1];
	}
	for($object in $baseObjList){
		string $childList[] = `listRelatives -pa -c -type "transform" $object`;
		int $listNum = AriUnparentOne_ListNum($object);
		string $baseName = $object;
		string $parentObj[] = `listRelatives -p -pa $object`;
		if($parentObj[0] != ""){
			string $unParent[] = `parent -w $object`;
			$object = $unParent[0];
		}
		string $parentGroup;
		string $childListWorld[];
		if(size($childList)){
			$parentGroup    = `group -em -name "AriReFreezeParent"`;
			$childListWorld = `parent $childList $parentGroup`;
		}
		string $objectIn[];
		if($manipTrue)	$objectIn = `parent $object $rotGroup`;
		else			$objectIn = `parent $object $targetObj`;
		$object = $objectIn[0];
		if($mode==0)makeIdentity -apply true -t 0 -r 1 -s 0 -n 0 $object;
		if($mode==1)setAttr ($object+".rotate") 0 0 0;
		string $outObj[];
		if($parentObj[0] != ""){
			string $parentGet[] = `listRelatives -p -pa $object`;
			if($parentObj[0] != $parentGet[0]){
				$outObj = `parent $object $parentObj[0]`;
				$object = $outObj[0];
			}
		}
		else{
			$outObj = `parent -w $object`;
			$object = $outObj[0];
		}
		reorder -relative ($listNum+1) $object;
		if($baseName != $object){
			rename $object $baseName;
		}
		string $parentList[];
		if(size($childList)){
			$parentList = `parent $childListWorld $object`;
			delete $parentGroup;
		}
		if($manipTrue) delete $rotGroup;
	}
	setAttr ($targetObj+".scale") ($targetScale.x) ($targetScale.y) ($targetScale.z);
	select $selectList;
}
global proc AriSetPivot_SetParentPivot(int $mode){
	string $selectList[] = getSelectToTransformList();
	string $parentList[];
	for($object in $selectList){
		string $parents[] = `listRelatives -p -pa $object`;	
		if(size($parents)==0) continue;
		select $parents;
		select -add $object;
		AriSetPivot_PivotRotate($mode,true);
		$parentList[size($parentList)] = $parents[0];
	}
	select $parentList;
}
proc int AriReFreezeT_AriListNum (string $obj){
	int $num;
	string $parent[]=`listRelatives -p -pa $obj`;
	string $children[];
	if($parent[0]=="")	$children=`ls -as`;
	else $children=		`listRelatives -c -pa $parent[0]`;
	int $i=0;
	for($child in $children){
		if($child == $obj){
			$num=$i;
			break;
		}
		$i++;
	}
	return $num;
}
proc string[] AriDisconnectAni(string $object){
	string $discone[3];
	string $transX[]=`listConnections -plugs true -d 0 -s 1  -type "animCurveTL" ($object+".translateX")`;
	string $transY[]=`listConnections -plugs true -d 0 -s 1  -type "animCurveTL" ($object+".translateY")`;
	string $transZ[]=`listConnections -plugs true -d 0 -s 1  -type "animCurveTL" ($object+".translateZ")`;
	if($transX[0]!="")disconnectAttr ($transX[0]) ($object+".translateX");
	if($transY[0]!="")disconnectAttr ($transY[0]) ($object+".translateY");
	if($transZ[0]!="")disconnectAttr ($transZ[0]) ($object+".translateZ");
	$discone[0]=$transX[0];
	$discone[1]=$transY[0];
	$discone[2]=$transZ[0];
	return $discone;
}
proc AriConnectAni(string $object,string $coneAttr[]){
	if($coneAttr[0]!="")connectAttr ($coneAttr[0]) ($object+".translateX");
	if($coneAttr[1]!="")connectAttr ($coneAttr[1]) ($object+".translateY");
	if($coneAttr[2]!="")connectAttr ($coneAttr[2]) ($object+".translateZ");
}
proc AriKeyFrameOfset(string $object, float $x ,float $y, float $z){
	string $transX[]=`listConnections   -d 0 -s 1  -type "animCurveTL" ($object+".translateX")`;
	string $transY[]=`listConnections   -d 0 -s 1  -type "animCurveTL" ($object+".translateY")`;
	string $transZ[]=`listConnections   -d 0 -s 1  -type "animCurveTL" ($object+".translateZ")`;
	if($transX[0]!="")keyframe -e -iub true -r -o over -vc $x $transX[0];
	if($transY[0]!="")keyframe -e -iub true -r -o over -vc $y $transY[0];
	if($transZ[0]!="")keyframe -e -iub true -r -o over -vc $z $transZ[0];
}
global proc  AriSetPivot_Save(){
	global string $AriSetPivot_UI_worldRB[];
	int $worldTrue = `radioButton -q -sl $AriSetPivot_UI_worldRB[0]`;
	optionVar -intValue  "AriSetPivot_world" $worldTrue;
}
global proc  AriSetPivot_Load(){
	global string $AriSetPivot_UI_worldRB[];
	int $worldTrue = true;
	if(`optionVar -exists "AriSetPivot_world"`)   $worldTrue   = `optionVar -q "AriSetPivot_world"`;
	if($worldTrue)	radioButton -e -sl $AriSetPivot_UI_worldRB[0];
	else			radioButton -e -sl $AriSetPivot_UI_worldRB[1];
}
global proc  AriSetPivot_Reload(){
	string $groupName = "AriSetPivot_Manip";
	if(`objExists $groupName`){
		delete $groupName;
		AriSetPivot_GO(1000);
	}
	AriSetPivot_Save();
}
proc string[] getSelectToVertexList(){
	string $selectList[]    = `ls -sl`;
	string $checkVerList[];
	$checkVerList = `filterExpand -selectionMask 31 $selectList`;
	string $works[];
	string $selectEdgeList[]=`filterExpand -selectionMask 32 $selectList`;
	if(size($selectEdgeList)>0 || size($checkVerList)==0){
		$works=`polyListComponentConversion -tv $selectEdgeList`;
		$works=`filterExpand -selectionMask 31 $works`;
		$checkVerList=$works;
	}
	string $selectFaceList[]=`filterExpand -selectionMask 34 $selectList`;
	if(size($selectFaceList)>0 || size($checkVerList)==0){
		$works=`polyListComponentConversion -tv $selectFaceList`;
		$works=`filterExpand -selectionMask 31 $works`;
		$checkVerList=$works;
	}
	return $checkVerList;
}
proc vector getParentWorldPos(string $obj){
	vector $parentWorldPos;
	string $parents[] = `listRelatives -p -pa $obj`;	
	if($parents[0] != ""){
		float $getW[] = `xform -q -ws -piv  $parents[0]`;
		$parentWorldPos = <<$getW[0], $getW[1], $getW[2]>>;
	}
	else{
		$parentWorldPos = <<0, 0, 0>>;
	}
	return $parentWorldPos;
}
global proc AriSetPivot_AriReFreezeTranslate_GO(int $mode){
	string $selectObj[]=`ls -sl -tr`;
	string $processedObjList[];
	int $i=0;
	for($obj in $selectObj){
		int $num=AriReFreezeT_AriListNum($obj);
		float $pos[3] = `xform -q -ws -rp $obj`;			
		string $parents[]=`listRelatives -p -pa $obj`;	
		string $childList[]=`listRelatives -c -type "transform" -pa $obj`;	
		string $childUnParentName[];
		int $j = 0;
		for($child in $childList){
			string $work[]=`parent -w $child`;
			$childUnParentName[$j] = $work[0];
			$j++;
		}
		string $wObj = $obj;
		float $beforeTr[3];
		float $afterTr[3];
		$beforeTr[0] = `getAttr ($wObj+".translateX")`;
		$beforeTr[1] = `getAttr ($wObj+".translateY")`;
		$beforeTr[2] = `getAttr ($wObj+".translateZ")`;
		string $discone[3]=AriDisconnectAni($wObj);
		if($mode==1){
			if($parents[0]!=""){
				string $work[]=`parent -w $obj`;
				$wObj = $work[0];
			}
			move -rpr 0 0 0 $wObj;		
		}
		makeIdentity -apply true -t 1 -r 0 -s 0 -n 0  $wObj;	
		if($mode==1){
			move -rpr ($pos[0]) ($pos[1]) ($pos[2]) $wObj;				
			if($parents[0]!=""){
				string $wObjParent[]=`parent  $wObj $parents[0]`;
				$wObj = $wObjParent[0];
				reorder -relative ($num+1) $wObj;
				if($wObj != $obj){
					string $sepa[];
					tokenize $obj "|" $sepa;
					string $baseName = $sepa[size($sepa)-1];
					$wObj =`rename $wObjParent[0] $baseName`;
				}
			}
			setAttr ($wObj+".rotatePivot") 0 0 0;
			setAttr ($wObj+".scalePivot")  0 0 0;
			setAttr ($wObj+".rotatePivotTranslate") 0 0 0;
			setAttr ($wObj+".scalePivotTranslate")  0 0 0;
		}
		$afterTr[0] = `getAttr ($wObj+".translateX")`;
		$afterTr[1] = `getAttr ($wObj+".translateY")`;
		$afterTr[2] = `getAttr ($wObj+".translateZ")`;
		AriConnectAni($wObj,$discone);
		float $dis[3];
		$dis[0] = $afterTr[0]-$beforeTr[0];
		$dis[1] = $afterTr[1]-$beforeTr[1];
		$dis[2] = $afterTr[2]-$beforeTr[2];
		AriKeyFrameOfset($wObj, $dis[0] , $dis[1], $dis[2]);
		for($j=0; $j<size($childUnParentName); $j++){
			string $work[] = `parent $childUnParentName[$j] $wObj`;
			string $nowChildName = $work[0];
			if($nowChildName != $childList[$j]){
				string $sepa[];
				tokenize $childList[$j] "|" $sepa;
				string $baseName = $sepa[size($sepa)-1];
				rename $nowChildName $baseName;
			}
		}
		if($mode==0){
			setAttr ($wObj+".translate") 0 0 0;
		}
		$processedObjList[$i] = $wObj;
		$i++;
	}
	select $processedObjList;
}
proc float[] AriSetPivot_ManipulatorPosition(){
	string $linear=`currentUnit -q -linear`;
	float $multiply = 1.0;
	if($linear=="mm")$multiply=0.1;
	if($linear=="cm")$multiply=1;
	if($linear=="m" )$multiply=100;
	if($linear=="in")$multiply=2.54;
	if($linear=="ft")$multiply=30.48;
	if($linear=="yd")$multiply=91.44;
	$multiply=1.0/($multiply);
	float $maniPosition[3];
	string $currentTool=`currentCtx`;
	if($currentTool=="moveSuperContext"){
		$maniPosition = `manipMoveContext -q -p Move`;
	}
	if($currentTool=="RotateSuperContext"){
		$maniPosition = `manipRotateContext -q -p Rotate`;
	}
	if($currentTool=="scaleSuperContext"){
		$maniPosition = `manipScaleContext -q -p Scale`;
	}
	$maniPosition[0] = $maniPosition[0] * $multiply;
	$maniPosition[1] = $maniPosition[1] * $multiply;
	$maniPosition[2] = $maniPosition[2] * $multiply;
	return $maniPosition;
}
global proc AriReFrTrPv_transformAttrZero(int $mode){
	string $selectObj[]=`ls -sl -tr`;
	for($obj in $selectObj){
		if($mode == 0) setAttr ($obj+".translate")  0 0 0;
		if($mode == 1) setAttr ($obj+".translateX") 0;
		if($mode == 2) setAttr ($obj+".translateY") 0;
		if($mode == 3) setAttr ($obj+".translateZ") 0;
		if($mode == 10) setAttr ($obj+".rotate")  0 0 0;
		if($mode == 11) setAttr ($obj+".rotateX") 0;
		if($mode == 12) setAttr ($obj+".rotateY") 0;
		if($mode == 13) setAttr ($obj+".rotateZ") 0;
	}
}
global proc AriSetPivot_getObjectPos(){
	global string $AriSetPivot_UI_attr[];
	global string $AriSetPivot_UI_position[];
	global string $AriSetPivot_UI_objectListSF;
	global string $AriSetPivot_UI_objectName;
	global int $AriSetPivot_JobNum;
	string $transformList[] = getSelectToTransformList();
	int $size = size($transformList)-1;
	if($size<0)$size=0;
	string $obj = $transformList[$size];
	string $selectText[] = `textScrollList -q -si $AriSetPivot_UI_objectListSF`;
	if($selectText[0] != ""){
		$obj = $selectText[0];
	}
	global int $AriSetPivot_CreateCone;
	string $transform[] =`ls -sl -tr`;
	textField -e -text $obj $AriSetPivot_UI_objectName;
	if($obj != ""){
		if(stringArrayContains($obj,$transform)){
			if($transform[size($transform)-1] != $obj){
				$AriSetPivot_CreateCone = true;
				select -d $obj;
				$AriSetPivot_CreateCone = true;
				select -add $obj;
			}
		}
	}
	if($obj != ""){
		attrFieldGrp -e -en 1 -attribute ($obj+".translate") $AriSetPivot_UI_attr[0];
		attrFieldGrp -e -en 1 -attribute ($obj+".rotatePivot") $AriSetPivot_UI_attr[1];
	}
	else{
		attrFieldGrp -e -en 0 $AriSetPivot_UI_attr[0];
		attrFieldGrp -e -en 0 $AriSetPivot_UI_attr[1];
	}
	if($obj != ""){
		vector $attrPos   = `getAttr ($obj+".translate")`;
		vector $pivRoPos    = `getAttr ($obj+".rotatePivot")`;
		vector $pivRoPosTr  = `getAttr ($obj+".rotatePivotTranslate")`;
		vector $pivScPos    = `getAttr ($obj+".scalePivot")`;
		vector $pivScPosTr  = `getAttr ($obj+".scalePivotTranslate")`;
		float $worldPos[] = `xform  -q -ws -piv  $obj`;
		floatField -e -en true -v ($attrPos.x) $AriSetPivot_UI_position[0];
		floatField -e -en true -v ($attrPos.y) $AriSetPivot_UI_position[1];
		floatField -e -en true -v ($attrPos.z) $AriSetPivot_UI_position[2];
		floatField -e -en true -v ($pivRoPos.x) $AriSetPivot_UI_position[3];
		floatField -e -en true -v ($pivRoPos.y) $AriSetPivot_UI_position[4];
		floatField -e -en true -v ($pivRoPos.z) $AriSetPivot_UI_position[5];
		floatField -e -en true -v ($pivRoPosTr.x) $AriSetPivot_UI_position[9];
		floatField -e -en true -v ($pivRoPosTr.x) $AriSetPivot_UI_position[10];
		floatField -e -en true -v ($pivRoPosTr.x) $AriSetPivot_UI_position[11];
		floatField -e -en true -v ($pivScPos.x) $AriSetPivot_UI_position[12];
		floatField -e -en true -v ($pivScPos.y) $AriSetPivot_UI_position[13];
		floatField -e -en true -v ($pivScPos.z) $AriSetPivot_UI_position[14];
		floatField -e -en true -v ($pivScPosTr.x) $AriSetPivot_UI_position[15];
		floatField -e -en true -v ($pivScPosTr.x) $AriSetPivot_UI_position[16];
		floatField -e -en true -v ($pivScPosTr.x) $AriSetPivot_UI_position[17];
		floatField -e -en true -v ($worldPos[3]) $AriSetPivot_UI_position[6];
		floatField -e -en true -v ($worldPos[4]) $AriSetPivot_UI_position[7];
		floatField -e -en true -v ($worldPos[5]) $AriSetPivot_UI_position[8];
	}
	else{
		attrFieldGrp -e -en 0 $AriSetPivot_UI_attr[0];
		attrFieldGrp -e -en 0 $AriSetPivot_UI_attr[1];
		floatField -e -en false $AriSetPivot_UI_position[0];
		floatField -e -en false $AriSetPivot_UI_position[1];
		floatField -e -en false $AriSetPivot_UI_position[2];
		floatField -e -en false $AriSetPivot_UI_position[3];
		floatField -e -en false $AriSetPivot_UI_position[4];
		floatField -e -en false $AriSetPivot_UI_position[5];
		floatField -e -en false $AriSetPivot_UI_position[6];
		floatField -e -en false $AriSetPivot_UI_position[7];
		floatField -e -en false $AriSetPivot_UI_position[8];
		floatField -e -en false $AriSetPivot_UI_position[9];
		floatField -e -en false $AriSetPivot_UI_position[10];
		floatField -e -en false $AriSetPivot_UI_position[11];
		floatField -e -en false $AriSetPivot_UI_position[12];
		floatField -e -en false $AriSetPivot_UI_position[13];
		floatField -e -en false $AriSetPivot_UI_position[14];
		floatField -e -en false $AriSetPivot_UI_position[15];
		floatField -e -en false $AriSetPivot_UI_position[16];
		floatField -e -en false $AriSetPivot_UI_position[17];
	}
}
global proc AriSetPivot_Manipulator(int $mode){
	string $transformObj[]=`ls -sl -tr`;
	string $objects[]=$transformObj;
	if(size($objects)==0){
		string $selectObj[]=`ls -sl`;
		string $vertexs[] = `polyListComponentConversion -tv $selectObj`;	
		if($vertexs[0]!=""){
			$objects = `polyListComponentConversion $vertexs`;	
			$objects = `listRelatives -p -pa -type "transform" $objects`;
		}
	}
	float $manuPos[] = AriSetPivot_ManipulatorPosition();
	string $currentTool=`currentCtx`;
	if($currentTool=="moveSuperContext" || $currentTool=="RotateSuperContext" || $currentTool=="scaleSuperContext"){
		if($mode==3){
			xform  -ws -piv $manuPos[0] $manuPos[1] $manuPos[2] $objects;
		}
		else{
			for($obj in $objects){
				float $pivPos[]=`xform -q -ws -piv $obj`;
				float $movePos[]=$pivPos;
				$movePos[$mode]=$manuPos[$mode];
				xform  -ws -piv $movePos[0] $movePos[1] $movePos[2] $obj;
			}
		}
	}
	AriSetPivot_getObjectPos();
}
global proc AriSetPivot_ManipulatorMove(int $mode){
	string $transformObj[]=`ls -sl -tr`;
	float $maniPos[3]=AriSetPivot_ManipulatorPosition();
	for($obj in $transformObj){
	if($mode==3)move -rpr ($maniPos[0]) ($maniPos[1]) ($maniPos[2]) $obj;
		else{
			float $movePos[] = `xform  -q -ws -piv  $obj`;
			$movePos[$mode]=$maniPos[$mode];
			move -rpr ($movePos[0]) ($movePos[1]) ($movePos[2]) $obj;
		}
	}
	AriSetPivot_getObjectPos();
}
proc float[] AriSetPivot_MimMax(string $verList[],int $worldTrue){
	global string $AriSetPivot_UI_worldRB[];
	float $minmax[];
	int $i=0;
	for($ver in $verList){
		float $verPos[] = `pointPosition -l $ver`;
		if($worldTrue){
			$verPos = `pointPosition -w $ver`;
		}
		if($i==0){
			$minmax[0] = $verPos[0];
			$minmax[1] = $verPos[1];
			$minmax[2] = $verPos[2];
			$minmax[3] = $verPos[0];
			$minmax[4] = $verPos[1];
			$minmax[5] = $verPos[2];
		}
		if($minmax[0] > $verPos[0]) $minmax[0] = $verPos[0];
		if($minmax[1] > $verPos[1]) $minmax[1] = $verPos[1];
		if($minmax[2] > $verPos[2]) $minmax[2] = $verPos[2];
		if($minmax[3] < $verPos[0]) $minmax[3] = $verPos[0];
		if($minmax[4] < $verPos[1]) $minmax[4] = $verPos[1];
		if($minmax[5] < $verPos[2]) $minmax[5] = $verPos[2];
		$i++;
	}
	return $minmax;
}
proc vector[] getSevenPosition(string $obj, string $transformList[], string $checkVerList[],int $worldTrue){
	vector $positionList[];
	int $groupTrue = false;
	string $verList[];
	if(stringArrayContains($obj, $transformList)){
		$verList = `polyListComponentConversion -tv $obj`;
		$verList = `filterExpand -selectionMask 31 $verList`;
		string $shapeList[] = `listRelatives  -c -s  $obj`;
		if(size($shapeList)==0)$groupTrue = true;
	}
	else{
		int $counter = 0;
		for($ver in $checkVerList){
			if(startsWith($ver,$obj)){
				$verList[$counter] = $ver;
				$counter++;
			}
		}
	}
	float $boundPos[] = AriSetPivot_MimMax($verList,$worldTrue);
	vector $pivPos;
	if($worldTrue){
		float $pos[] = `xform -q -ws -piv  $obj`;
		$pivPos = <<$pos[0], $pos[1], $pos[2]>>;
	}
	else{
		float $pos[] = `xform -q     -piv  $obj`;
		$pivPos = <<$pos[0], $pos[1], $pos[2]>>;
		if($groupTrue==true){
			string $parents[] = `listRelatives -p -pa $obj`;	
			int $num = AriReFreezeT_AriListNum($obj);
			string $wObj = $obj;
			if($parents[0] != ""){
				string $work[] = `parent -w $obj`;
				$wObj = $work[0];
			}
			vector $beforeTranslate = `getAttr ($wObj+".translate")`;
			vector $beforeRotate    = `getAttr ($wObj+".rotate")`;
			vector $beforeScale     = `getAttr ($wObj+".scale")`;
			vector $beforeShear     = `getAttr ($wObj+".shear")`;
			setAttr ($wObj+".translate") 0 0 0;
			setAttr ($wObj+".rotate") 0 0 0;
			setAttr ($wObj+".scale") 1 1 1;
			setAttr ($wObj+".shearXY") 0;
			setAttr ($wObj+".shearXZ") 0;
			setAttr ($wObj+".shearYZ") 0;
			float $pos[] = `xform -q     -piv  $wObj`;
			$pivPos = <<$pos[0], $pos[1], $pos[2]>>;
			float $beforePivot[]  = `xform -q -os -piv $wObj`;
			xform -os -piv 0 0 0 $wObj;
			float $getW[] = `xform -q -ws -piv  $wObj`;
			vector $worldPos = <<$getW[0], $getW[1], $getW[2]>>;
			$verList = `polyListComponentConversion -tv $wObj`;
			$verList = `filterExpand -selectionMask 31 $verList`;
			$boundPos = AriSetPivot_MimMax($verList,true);
			xform -sp $pos[0] $pos[1] $pos[2] $wObj;
			xform -rp $pos[3] $pos[4] $pos[5] $wObj;
			setAttr ($wObj+".shearXY") ($beforeShear.x);
			setAttr ($wObj+".shearXZ") ($beforeShear.y);
			setAttr ($wObj+".shearYZ") ($beforeShear.z);
			setAttr ($wObj+".scale")     ($beforeScale.x)  ($beforeScale.y)  ($beforeScale.z);
			setAttr ($wObj+".rotate")    ($beforeRotate.x) ($beforeRotate.y) ($beforeRotate.z);
			setAttr ($wObj+".translate") ($beforeTranslate.x) ($beforeTranslate.y) ($beforeTranslate.z);
			if($parents[0] != ""){
				string $wObjParent[]=`parent  $wObj $parents[0]`;
				$wObj = $wObjParent[0];
				reorder -relative ($num+1) $wObj;
				if($wObj != $obj){
					string $sepa[];
					tokenize $obj "|" $sepa;
					string $baseName = $sepa[size($sepa)-1];
					$wObj =`rename $wObjParent[0] $baseName`;
				}
			}
			$boundPos[0] = $boundPos[0] - ($worldPos.x);
			$boundPos[1] = $boundPos[1] - ($worldPos.y);
			$boundPos[2] = $boundPos[2] - ($worldPos.z);
			$boundPos[3] = $boundPos[3] - ($worldPos.x);
			$boundPos[4] = $boundPos[4] - ($worldPos.y);
			$boundPos[5] = $boundPos[5] - ($worldPos.z);
		}
	}
	vector $center = << (($boundPos[0] + $boundPos[3]) * 0.5), (($boundPos[1] + $boundPos[4]) * 0.5), (($boundPos[2] + $boundPos[5]) * 0.5)   >>;
	$positionList[0] = <<$boundPos[0], ($pivPos.y),  ($pivPos.z) >>;
	$positionList[1] = <<($pivPos.x),  $boundPos[1], ($pivPos.z) >>;
	$positionList[2] = <<($pivPos.x),  ($pivPos.y),  $boundPos[2]>>;
	$positionList[3] = <<$boundPos[3], ($pivPos.y),  ($pivPos.z) >>;
	$positionList[4] = <<($pivPos.x),  $boundPos[4], ($pivPos.z) >>;
	$positionList[5] = <<($pivPos.x),  ($pivPos.y),  $boundPos[5]>>;	
	$positionList[6] = $center; 
	$positionList[7] = $pivPos; 
	$positionList[8]  = <<$center.x, $pivPos.y, $pivPos.z>>;
	$positionList[9]  = <<$pivPos.x, $center.y, $pivPos.z>>;
	$positionList[10] = <<$pivPos.x, $pivPos.y, $center.z>>;
	return $positionList;
}
global proc AriSetPivot_ViewPiv(){
	string $checkObjectList[] = getSelectToTransformList();
	int $asisTrue = false;
	for($obj in $checkObjectList){
		if(`getAttr ($obj+".displayLocalAxis")`){
			$asisTrue = true;
			break;
		}
	}
	int $viewTrue = !$asisTrue;
	for($obj in $checkObjectList){
		int $handleTrue = `setAttr ($obj+".displayScalePivot")`;
		setAttr ($obj+".displayScalePivot") $viewTrue;
		setAttr ($obj+".displayLocalAxis") $viewTrue;
		refresh;
		setAttr ($obj+".displayScalePivot") $handleTrue;
	}
}
global proc AriSetPivot_GO(int $mode){
	global string $AriReFreezeHighCB;
	global string $AriSetPivot_UI_worldRB[];
	global int $AriSetPivot_JobConeSelectNum;
	global int $AriSetPivot_CreateCone;
	global string $AriSetPivot_currentTool;
	global string $AriSetPivot_beforeSelectList[];
	string $groupName = "AriSetPivot_Manip";
	int $worldTrue = `radioButton -q -sl $AriSetPivot_UI_worldRB[0]`;
	if($mode==30 || $mode==31 || $mode==32 || $mode==33){
		$worldTrue = true;
	}
	string $transformList[] = `ls -sl -tr`;
	string $checkObjectList[] = getSelectToTransformList();
	string $checkVerList[]    = getSelectToVertexList();
	if(size($checkObjectList)==0)return;
	string $warningObj[];
	clear $warningObj;
	if($mode!=1000){
		for($obj in $checkObjectList){
			vector $sevenPosition[] = getSevenPosition($obj, $transformList, $checkVerList, $worldTrue);
			if($mode==0) $movePivPos = $sevenPosition[0];
			if($mode==1) $movePivPos = $sevenPosition[1];
			if($mode==2) $movePivPos = $sevenPosition[2];
			if($mode==3) $movePivPos = $sevenPosition[3];
			if($mode==4) $movePivPos = $sevenPosition[4];
			if($mode==5) $movePivPos = $sevenPosition[5];
			if($mode==50)$movePivPos = $sevenPosition[6];
			if($mode==8) $movePivPos = $sevenPosition[8];
			if($mode==9) $movePivPos = $sevenPosition[9];
			if($mode==10)$movePivPos = $sevenPosition[10];
			if($mode==30 || $mode==31 || $mode==32 || $mode==33){
				vector $nowPivPos = $sevenPosition[7];
				if($mode==30) $movePivPos = <<0,0,0>>;
				if($mode==31) $movePivPos = <<0, ($nowPivPos.y), ($nowPivPos.z)>>;
				if($mode==32) $movePivPos = <<($nowPivPos.x), 0, ($nowPivPos.z)>>;
				if($mode==33) $movePivPos = <<($nowPivPos.x), ($nowPivPos.y), 0>>;
			}
			if($mode==20 || $mode==21 || $mode==22 || $mode==23){
				vector $nowPivPos = `xform -q -piv $obj`;
				if($mode==20) $movePivPos = <<0,0,0>>;
				if($mode==21) $movePivPos = <<0, ($nowPivPos.y), ($nowPivPos.z)>>;
				if($mode==22) $movePivPos = <<($nowPivPos.x), 0, ($nowPivPos.z)>>;
				if($mode==23) $movePivPos = <<($nowPivPos.x), ($nowPivPos.y), 0>>;
			}
			if($mode==20 || $mode==21 || $mode==22 || $mode==23){
				xform      -piv ($movePivPos.x) ($movePivPos.y) ($movePivPos.z) $obj;
			}
			else{
				if($worldTrue)	xform -ws -piv ($movePivPos.x) ($movePivPos.y) ($movePivPos.z) $obj;
				else			xform -os -piv ($movePivPos.x) ($movePivPos.y) ($movePivPos.z) $obj;
			}
		}
		AriSetPivot_getObjectPos();
		string $warningLabel = "";
		if(size($warningObj)){
			for($war in $warningObj){
				$warningLabel = $warningLabel + $war +", ";
			}
			$warningLabel = $warningLabel + "はグループのためLocalでは機能しません";
			warning ($warningLabel);
		}
		if(`objExists $groupName`){
			setToolTo $AriSetPivot_currentTool;
		}
	}
	else{
		$AriSetPivot_CreateCone = true;
		if(`objExists $groupName`){
			delete $groupName;
			setToolTo $AriSetPivot_currentTool;
			return;
		}
		$AriSetPivot_beforeSelectList = `ls -sl`;
		string $obj = $checkObjectList[size($checkObjectList)-1];
		vector $sevenPosition[] = getSevenPosition($obj, $transformList, $checkVerList, $worldTrue);
		undoInfo -swf 0;
		$AriSetPivot_currentTool = `currentCtx`;
		setToolTo "selectSuperContext";
		string $nameList[] = {	"AriSetPivot_X_m","AriSetPivot_Y_m","AriSetPivot_Z_m",
								"AriSetPivot_X_p","AriSetPivot_Y_p","AriSetPivot_Z_p"};
		vector $axList[];
		$axList[0] = <<  1,  0,  0>>;
		$axList[1] = <<  0,  1,  0>>;
		$axList[2] = <<  0,  0,  1>>;
		$axList[3] = << -1,  0,  0>>;
		$axList[4] = <<  0, -1,  0>>;
		$axList[5] = <<  0,  0, -1>>;
		vector $colorList[];
		$colorList[0] = <<0.5, 0.0, 0.0>>;
		$colorList[1] = <<0.0, 0.5, 0.0>>;
		$colorList[2] = <<0.0, 0.0, 0.5>>;
		$colorList[3] = <<1.0, 0.0, 0.0>>;
		$colorList[4] = <<0.0, 1.0, 0.0>>;
		$colorList[5] = <<0.0, 0.0, 1.0>>;
		float $height = 0.5;
		float $scale  = 5;
		float $bounding[] = `exactWorldBoundingBox $obj`;
		float $maxDistance = `abs ($bounding[3]-$bounding[0])`;
		if($maxDistance < `abs($bounding[3]-$bounding[0])` ) $maxDistance = `abs($bounding[3]-$bounding[0])`;
		if($maxDistance < `abs($bounding[4]-$bounding[1])` ) $maxDistance = `abs($bounding[4]-$bounding[1])`;
		if($maxDistance < `abs($bounding[5]-$bounding[2])` ) $maxDistance = `abs($bounding[5]-$bounding[2])`;
		$scale  = $maxDistance * 0.5;
		string $coneList[];
		int $jj = 0;
		for($ii=0; $ii < 6; $ii++){
			vector $ax = $axList[$ii];
			string $cone[] = `polyCone -r 0.5 -h $height -sx 4 -sy 1 -sz 0 -ax ($ax.x) ($ax.y) ($ax.z) -rcp 0 -cuv 3 -ch 1 -n $nameList[$ii]`;
			vector $col = $colorList[$ii];
			move ($ax.x * $height * -0.5) ($ax.y * $height * -0.5) ($ax.z * $height * -0.5) $cone[0];
			xform -ws -piv 0 0 0 $cone[0];
			makeIdentity -apply true -t 1 -r 0 -s 1 -n 0 -pn 1 $cone[0];
			polyColorPerVertex -r ($col.x) -g ($col.y) -b ($col.z) -a 1 -cdo $cone[0];
			setAttr ($cone[0] + ".overrideEnabled") 1;
			setAttr ($cone[0] + ".overrideColorRGB") ($col.x) ($col.y) ($col.z);
			setAttr ($cone[0] + ".overrideRGBColors") 1;
			vector $pos = $sevenPosition[$ii];
			if($worldTrue){
				move -rpr ($pos.x) ($pos.y) ($pos.z) $cone[0];
			}
			else{
				move -os ($pos.x) ($pos.y) ($pos.z) $cone[0];
			}
			$coneList[$jj] = $cone[0];
			$jj++;
		}
		string $group =`group -n $groupName $coneList[0] $coneList[1] $coneList[2] $coneList[3] $coneList[4] $coneList[5]`;
		if(!$worldTrue){
			string $parent[] = `parent $group $obj`;
			$group = $parent[0];
			setAttr ($group+".rotate")    0 0 0;
			setAttr ($group+".scale")     1 1 1;
			setAttr ($group+".shear")     0 0 0;
			setAttr ($group+".translate") 0 0 0;
			setAttr ($group+".rotatePivotTranslate") 0 0 0;
			setAttr ($group+".scalePivotTranslate")  0 0 0;
			parent -w $group; 
			for($ii=0; $ii < size($coneList); $ii++){
				string $work[] = `parent -w $coneList[$ii]`;
				$coneList[$ii] = $work[0];
			}
			delete $group;
			$group =`group -n "AriSetPivot_Manip" $coneList[0] $coneList[1] $coneList[2] $coneList[3] $coneList[4] $coneList[5]`;
		}
		for($ii=0; $ii < size($coneList); $ii++){
			setAttr ($coneList[$ii]+".scale")  $scale $scale $scale  ;
		}
		string $sourcePanelList[] = `getPanel-type modelPanel`;
		for($sourcePanel in $sourcePanelList){
			if(`modelEditor -ex $sourcePanel`)isolateSelect -ado $group $sourcePanel ;
		}
		select $AriSetPivot_beforeSelectList;
		undoInfo -swf 1;
	}
}
