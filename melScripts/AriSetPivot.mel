global proc AriSetPivot_moveLocalZero(int $mode, int $moveTrue){
	string $transformList[] = getSelectToTransformList();
	for($obj in $transformList){
		vector $parentPos = getParentWorldPos($obj);
		if(!$moveTrue){
			xform -ws -piv ($parentPos.x) ($parentPos.y) ($parentPos.z) $obj;
		}
		else{
			move -rpr ($parentPos.x) ($parentPos.y) ($parentPos.z) $obj;
		}
	}
	AriSetPivot_getObjectPos();
}
global proc AriSetPivot_moveLocalZeroOld(int $mode){
	string $transformObj[]=`ls -sl -tr`;
	float $movePos[3];
	float $worldPivPos[];
	float $LocalPivPos[];
	$movePos[0]=0;
	$movePos[1]=0;
	$movePos[2]=0;
	for($obj in $transformObj){
		if($mode==0){
			setAttr ($obj+".translate") 0 0 0;
			float $pivPos[3]=`xform -q -piv $obj`;
			move -r ($pivPos[0]*-1) ($pivPos[1]*-1) ($pivPos[2]*-1) $obj;
		}
		if($mode==1){
			setAttr ($obj+".translateX") 0;
			float $pivPos[3]=`xform -q -piv $obj`;
			move -r ($pivPos[0]*-1) 0 0 $obj;
		}
		if($mode==2){
			setAttr ($obj+".translateY") 0;
			float $pivPos[3]=`xform -q -piv $obj`;
			move -r 0 ($pivPos[1]*-1) 0 $obj;
		}
		if($mode==3){
			setAttr ($obj+".translateZ") 0;
			float $pivPos[3]=`xform -q -piv $obj`;
			move -r 0 0 ($pivPos[2]*-1) $obj;
		}
	}
	AriSetPivot_getObjectPos();
}
proc int AriNumber2to10(int $boolList[]){
	int $number;
	int $baisu=1;
	for($i=0;$i<size($boolList);$i++){
		$number += $baisu*$boolList[$i];
		$baisu = $baisu*2;
	}
	return $number;	
}
proc int[] AriNumber10to2(int $number){
	int $boolList[];
	int $baisu=pow(2,20);
	$amari=$number;
	for($i=20;$i>=0;$i--){
		if($amari-$baisu>=0){
			$amari=$amari-$baisu;
			$boolList[$i]=1;
		}
		else $boolList[$i]=0;
		$baisu=$baisu/2;
	}
	return $boolList;
}
global proc AriSetPivot_save(){
	global string $AriReFreezeTrFrame[8];
	global string $AriReFreezeHighCB;
	int $frame[5];
	$frame[0] = `frameLayout -q -cl $AriReFreezeTrFrame[0]`;
	$frame[1] = `frameLayout -q -cl $AriReFreezeTrFrame[1]`;
	$frame[2] = `frameLayout -q -cl $AriReFreezeTrFrame[2]`;
	$frame[3] = 0;
	$frame[4] = `frameLayout -q -cl $AriReFreezeTrFrame[4]`;
	$frame[5] =	`frameLayout -q -cl $AriReFreezeTrFrame[5]`;
	$frame[6] =	`frameLayout -q -cl $AriReFreezeTrFrame[6]`;
	int $saveVal = AriNumber2to10($frame);
	optionVar -intValue "AriReFreezeTr_frameCollapse" $saveVal;
}
global proc AriSetPivot_JudgeCone(){
	global int    $AriSetPivot_JobConeSelectNum;
	global string $AriSetPivot_beforeSelectList[];
	global string $AriSetPivot_currentTool;
	string $groupName = "AriSetPivot_Manip";
	if(!`objExists $groupName`)return;
	string $nameList[] = {	"AriSetPivot_X_m","AriSetPivot_Y_m","AriSetPivot_Z_m",
							"AriSetPivot_X_p","AriSetPivot_Y_p","AriSetPivot_Z_p"};
	string $selectObjs[] = `ls -sl -tr`;
	string $selectObj = $selectObjs[0];
	/*
	if(!stringArrayContains($selectObj,$nameList)){
		if($selectObj != $groupName){
			undoInfo -swf 0;
			delete "AriSetPivot_Manip";
			undoInfo -swf 1;
		}
		return;
	}
	*/
	if(stringArrayContains($selectObj,$nameList)){
		select $AriSetPivot_beforeSelectList;
		if($selectObj == $nameList[0]) AriSetPivot_GO(0);
		if($selectObj == $nameList[1]) AriSetPivot_GO(1);
		if($selectObj == $nameList[2]) AriSetPivot_GO(2);
		if($selectObj == $nameList[3]) AriSetPivot_GO(3);
		if($selectObj == $nameList[4]) AriSetPivot_GO(4);
		if($selectObj == $nameList[5]) AriSetPivot_GO(5);
	}
	undoInfo -swf 0;
	delete "AriSetPivot_Manip";
	undoInfo -swf 1;
	setToolTo $AriSetPivot_currentTool;
}
global proc AriSetPivot_getObjectList(){
	global string $AriSetPivot_UI_objectListSF;
	string $transformList[] = getSelectToTransformList();
	string $nameList[] = {	"AriSetPivot_X_m","AriSetPivot_Y_m","AriSetPivot_Z_m",
							"AriSetPivot_X_p","AriSetPivot_Y_p","AriSetPivot_Z_p","AriSetPivot_Manip"};
	string $allList[] = `textScrollList -q -ai $AriSetPivot_UI_objectListSF`;
	int $listTrue = false;
	if(size($allList) != size($transformList))$listTrue = true;
	for($list in $allList){	
		if(!stringArrayContains($list,$transformList)){
			$listTrue = true;
			break;
		}
	}
	if(size($transformList)==0)$listTrue = true;
	if(size($allList)==0)$listTrue = true;
	if($listTrue){
		textScrollList -e -ra  $AriSetPivot_UI_objectListSF;
		for($obj in $transformList){
			if(stringArrayContains($obj,$nameList))continue;
			textScrollList -e -a $obj $AriSetPivot_UI_objectListSF;
		}
		int $total = `textScrollList -q -ni $AriSetPivot_UI_objectListSF`;
		int $index = size($transformList);
		if($index<=$total){
			if($index != 0)textScrollList -e -sii $index $AriSetPivot_UI_objectListSF;
		}
	}
}
global proc AriSetPivot_changeSelect_GO(){
	global int $AriSetPivot_CreateCone;
	if($AriSetPivot_CreateCone==true){
		$AriSetPivot_CreateCone = false;
		return;
	}
	AriSetPivot_getObjectList(); 
	AriSetPivot_getObjectPos(); 
	AriSetPivot_JudgeCone(); 
}
global proc AriSetPivot_setObject(int $mode){
	global string $AriSetPivot_UI_attr[];
	global string $AriSetPivot_UI_position[];
	string $transformList[] = getSelectToTransformList();
	int $size = size($transformList)-1;
	if($size<0)$size=0;
	string $parentObj = $transformList[$size];
	if($parentObj != ""){
		float $val = `floatField -q -v $AriSetPivot_UI_position[$mode]`;
		for($obj in $transformList){
			if($mode==0) setAttr ($obj+".translateX") $val;
			if($mode==1) setAttr ($obj+".translateY") $val;
			if($mode==2) setAttr ($obj+".translateZ") $val;
			if($mode==3 || $mode==4 || $mode==5){
				float $movePivPos[] = `xform -q -rp $obj`;
				if($mode==3) $movePivPos[0] = $val;
				if($mode==4) $movePivPos[1] = $val;
				if($mode==5) $movePivPos[2] = $val;
				xform -rp $movePivPos[0] $movePivPos[1] $movePivPos[2] $obj;
			}
			if($mode==12 || $mode==13 || $mode==14){
				float $movePivPos[] = `xform -q -sp $obj`;
				if($mode==12) $movePivPos[0] = $val;
				if($mode==13) $movePivPos[1] = $val;
				if($mode==14) $movePivPos[2] = $val;
				xform -sp $movePivPos[0] $movePivPos[1] $movePivPos[2] $obj;
			}	
			if($mode==6 || $mode==7 || $mode==8){
				float $movePivPos[] = `xform -q -ws -piv $obj`;
				if($mode==6)move -rpr -x $val 0 0 $obj;
				if($mode==7)move -rpr -y $val 0 0 $obj;
				if($mode==8)move -rpr -z $val 0 0 $obj;
			}
			float $gosa = 0.0001;
			vector $rpt = `getAttr ($obj+".rotatePivotTranslate")`;
			if(($rpt.x) < $gosa && ($rpt.x) > ($gosa*-1))	setAttr ($obj+".rotatePivotTranslateX") 0;
			if(($rpt.y) < $gosa && ($rpt.y) > ($gosa*-1))	setAttr ($obj+".rotatePivotTranslateY") 0;
			if(($rpt.z) < $gosa && ($rpt.z) > ($gosa*-1))	setAttr ($obj+".rotatePivotTranslateZ") 0;
			vector $spt = `getAttr ($obj+".scalePivotTranslate")`;
			if(($rpt.x) < $gosa && ($rpt.x) > ($gosa*-1))	setAttr ($obj+".scalePivotTranslateX") 0;
			if(($rpt.y) < $gosa && ($rpt.y) > ($gosa*-1))	setAttr ($obj+".scalePivotTranslateY") 0;
			if(($rpt.z) < $gosa && ($rpt.z) > ($gosa*-1))	setAttr ($obj+".scalePivotTranslateZ") 0;
			/*
			if($mode==6 || $mode==7 || $mode==8){
				float $movePivPos[] = `xform -q -ws -piv $obj`;
				if($mode==6)$movePivPos[0]=$val;
				if($mode==7)$movePivPos[1]=$val;
				if($mode==8)$movePivPos[2]=$val;
				xform -ws -piv $movePivPos[0] $movePivPos[1] $movePivPos[2] $obj;
			}
			*/
		}
	}
	AriSetPivot_getObjectPos();
}
global proc AriSetPivot_ValueZero(int $mode){
	global string $AriSetPivot_UI_position[];
		floatField -e -v 0 $AriSetPivot_UI_position[$mode];
		AriSetPivot_setObject($mode);
		floatField -e -v 0 $AriSetPivot_UI_position[$mode+1];
		AriSetPivot_setObject($mode+1);
		floatField -e -v 0 $AriSetPivot_UI_position[$mode+2];
		AriSetPivot_setObject($mode+2);
}
global proc AriSetPivot_windowSize(){
	global string $AriReFreezeTrFrame[8];
	AriSetPivot_save();
	if(`frameLayout -q -cl $AriReFreezeTrFrame[4]`){
		window -e -h 50  AriSetPivot;
	}
}
global proc AriSetPivot(){
	global string $AriReFreezeTrFrame[5];
	global string $AriReFreezeHighCB;
	global int    $AriSetPivot_JobNum;
	global string $AriSetPivot_UI_attr[];
	global string $AriSetPivot_UI_position[];
	global string $AriSetPivot_UI_objectListSF;
	global string $AriSetPivot_UI_objectName;
	global string $AriSetPivot_UI_worldRB[];
	global int $AriSetPivot_CreateCone;
	global string $AriSetPivot_currentTool;
	$AriSetPivot_CreateCone = false;
	string $JPTrue;
	if(`about -uil`=="ja_JP")$JPTrue = true;
	else $JPTrue = false;
	string $label_ManipPiv  = "マニピュレータ位置(Pivot)";
	string $label_ManipMove = "マニピュレータ位置(Move)";
	string $label_wOriginPiv = "W原点(pivot)";
	string $label_lOriginPiv = "L原点(pivot)";
	string $label_wOriginMove = "W原点(Move)";
	string $label_lOriginMove = "L原点(Move)";
	string $label_transAttrZero  = "移動アトリビュート値 0";
	string $label_rotateAttrZero = "回転アトリビュート値 0";
	string $label_rightOption = "右クリックで X Y Z 軸選択";
	string $label_manuOrient = "マニピュレーター回転方向";
	string $label_SetParentPivot = "回転値を親に転送";
	if($JPTrue==false){
		$label_ManipPiv  = "Manipulator Pos (Pivot)";
		$label_ManipMove = "Manipulator Pos (Move)";
		$label_wOriginPiv = "World Origin";
		$label_lOriginPiv = "Local Origin";
		$label_wOriginMove = "World Origin";
		$label_lOriginMove = "Local Origin";
		$label_transAttrZero    = "Translate Attribute 0";
		$label_rotateAttrZero    = "Rotate Attribute 0";
		$label_rightOption = "Right click to select axis X Y Z";
		$label_manuOrient  = "Manipulator Orient";
		$label_SetParentPivot = "Set Parent Pivot";
	}
	float $valA=0.8;
	float $valB=0.4;
	float $valC=0.5;
	float $valD=0;
	float $rgb_r1[3]={$valA,$valB,$valB};
	float $rgb_g1[3]={$valB,$valA,$valB};
	float $rgb_b1[3]={$valB,$valB,$valA};
	float $rgb_r2[3]={$valC,$valD,$valD};
	float $rgb_g2[3]={$valD,$valC,$valD};
	float $rgb_b2[3]={$valD,$valD,$valC};
	$AriSetPivot_currentTool = `currentCtx`;
	int $frameCl[8];
	if(`optionVar -exists "AriReFreezeTr_frameCollapse"`){
		int $loadVal = `optionVar -q "AriReFreezeTr_frameCollapse"`;
		$frameCl = AriNumber10to2($loadVal);
	}
	string $button[10];
	string $form;
	string $formChild;
	string $buttonChild[];
	if((`window -ex AriSetPivot`)==true)deleteUI AriSetPivot;
	window -tlb 1 -title "AriSetPivot"  -w 200 -h 100 -mxb 0  AriSetPivot;
	string $mainForm = `formLayout `;
	$AriReFreezeTrFrame[4] = `frameLayout -cll 1 -cl $frameCl[4] -bgc 0.2 0.2 0.2 -l "Select List" -cc "AriSetPivot_windowSize();" -ec "AriSetPivot_windowSize();"`;
	string $formList = `formLayout`;
	$AriSetPivot_UI_objectListSF = `textScrollList -w 10 -h 50 -sc "AriSetPivot_getObjectPos();"`;
	setParent..;
	formLayout -e
	-af $AriSetPivot_UI_objectListSF "top"    0
	-af $AriSetPivot_UI_objectListSF "right"  0
	-af $AriSetPivot_UI_objectListSF "left"   0
	-af $AriSetPivot_UI_objectListSF "bottom" 0
	$formList;
	setParent..;
	string $mainForm_child2 = `columnLayout -adj true `;
	$AriReFreezeTrFrame[5] = `frameLayout -cll 1 -cl $frameCl[5] -bgc 0.2 0.2 0.2 -l "Position" -cc "AriSetPivot_windowSize();" -ec "AriSetPivot_windowSize();"`;
	columnLayout -adj true;
	$AriSetPivot_UI_objectName = `textField -ed false -bgc 0.1 0.1 0.1`;
	string $form3;
	columnLayout -adj true ;
	rowLayout -nc 2 -adj 1;
	text -l "Translate Attribute" -align "left";;
	button -l "0" -w 24 -h 16 -c "AriSetPivot_ValueZero(0)";
	setParent..;
	$form3 = `formLayout`;
	$AriSetPivot_UI_position[0] = `floatField -cc "AriSetPivot_setObject(0);"`;
	$AriSetPivot_UI_position[1] = `floatField -cc "AriSetPivot_setObject(1);"`;
	$AriSetPivot_UI_position[2] = `floatField -cc "AriSetPivot_setObject(2);"`;
