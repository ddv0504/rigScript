		$button[1]=`button -bgc $rgb_g1[0] $rgb_g1[1] $rgb_g1[2] -w 30 -h 10 -l "Y Max" -c "AriSetPivot_GO(4);AriSetPivot_Reload();"`;
		$button[2]=`button -bgc $rgb_b1[0] $rgb_b1[1] $rgb_b1[2] -w 30 -h 10 -l "Z Max" -c "AriSetPivot_GO(5);AriSetPivot_Reload();"`;
