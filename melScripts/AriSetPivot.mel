	columnLayout -adj true -co both 4;
	iconTextButton -h 28  -bgc $valA $valA $valB -st "iconAndTextHorizontal" -l $label_ManipPiv -i "out_holder.png" -c "AriSetPivot_Manipulator(3)" -ann $label_rightOption;
	popupMenu;
