	string $transformObj[]=`ls -sl -tr`;
	vector $afterPos[];
	int $i=0;
	for($obj in $transformObj){
		float $pos[] = `xform  -q -ws -piv  $obj`;
		$afterPos[$i] = <<$pos[0],$pos[1],$pos[2]>>;
		$i++;
	}
	int $time=`currentTime -q`;
	currentTime ($time+1);
