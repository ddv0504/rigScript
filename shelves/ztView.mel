        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "menuIconDisplay.png" 
        -image1 "menuIconDisplay.png" 
        -style "iconOnly" 
        -marginWidth 1
        -marginHeight 1
        -command "curPanel = cmds.getPanel(withFocus=True)\nstate = cmds.modelEditor(curPanel, q=True, polymeshes=True)\nif state:\n    cmds.modelEditor(curPanel, e=True, polymeshes=False)\nelse:\n    cmds.modelEditor(curPanel, e=True, polymeshes=True)" 
        -sourceType "python" 
